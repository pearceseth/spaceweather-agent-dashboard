# Dependencies - will be installed fresh in container
node_modules/
.pnpm-store/

# Build outputs - will be rebuilt in container
dist/
.next/
out/

# Git and version control
.git/
.gitignore

# Documentation - not needed at runtime
docs/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment files - secrets injected at runtime
.env
.env.local
.env.*.local

# Test and coverage
coverage/
*.test.ts
*.spec.ts
__tests__/

# Turbo cache
.turbo/

# TypeScript build info
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Claude working files
.claude/

# Docker files (avoid recursive copy)
docker-compose*.yml
Dockerfile*
